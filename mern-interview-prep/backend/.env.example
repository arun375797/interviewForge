ADMIN_PASSWORD=Job@2026
ADMIN_NAME=Arun
SYNC_ADMIN_PASSWORD=false

# Comma-separated frontend origins for CORS
CLIENT_URL=http://localhost:5173

# Comma-separated emails allowed to add/edit/delete questions
ADMIN_EMAILS=arun37579@gmail.com,arun375797@gmail.com,arun375797

# Google OAuth — same Client ID as frontend VITE_GOOGLE_CLIENT_ID
