PORT=5000
NODE_ENV=development
SERVE_FRONTEND=false

# MongoDB connection string (include database name in path)
MONGO_URI=mongodb://127.0.0.1:27017/mern_interview_prep

# JWT — use a long random string (32+ chars) in production
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES=7d

# Bootstrap admin (required — choose your own strong password)
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=choose-a-strong-password-here
ADMIN_NAME=Admin
SYNC_ADMIN_PASSWORD=false

# Comma-separated frontend origins for CORS
CLIENT_URL=http://localhost:5173

# Comma-separated emails allowed to add/edit/delete questions
ADMIN_EMAILS=your-admin@example.com

# Google OAuth — same Client ID as frontend VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
